{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Logical vs Physical Storage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "fabric_logical_storage_bytes", "legendFormat": "Logical" },
        { "expr": "sum(minio_node_disk_used_bytes)", "legendFormat": "Physical" }
      ],
      "fieldConfig": {
        "values": true,
        "defaults": { "unit": "decbytes" }
      }
    },
    {
      "title": "Per-Node Storage Distribution",
      "type": "barconfig",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "minio_node_disk_used_bytes", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Network Throughput (Total Receive)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(container_network_receive_bytes_total[5m]))", "legendFormat": "Total Throughput" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "Transaction Latency (P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(fabric_transaction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P99 Latency" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "CPU Utilization per Worker",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name=~\"fabric-worker-.*\"}[5m])", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "title": "Memory Utilization (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "container_memory_rss{name=~\"fabric-worker-.*\"}", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "title": "Node Status (Failure Detection)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "targets": [
        { "expr": "up{job=\"fabric-peers\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["fabric", "distributed"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Fabric Decentralized Architecture",
  "uid": "fabric-dashboard-001",
  "version": 1,
  "weekStart": ""
}
